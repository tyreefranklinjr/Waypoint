# Auth Service Configuration
APP_NAME=auth-service
ENVIRONMENT=development
PORT=8000

# Security (JWT)
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=your_super_secret_random_hex_string_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (Auth isolated database)
DB_HOST=localhost
DB_PORT=5432
DB_USER=auth_user
DB_PASSWORD=auth_secure_password
DB_NAME=auth_db